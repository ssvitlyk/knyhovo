// append-only rule: price_history rows are INSERT-only. No UPDATE or DELETE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Provider {
  YAKABOO   @map("yakaboo")
  BOOK_CLUB @map("book-club")
  VIVAT     @map("vivat")
  BOOK_YE   @map("book-ye")

  @@map("provider")
}

enum Currency {
  UAH

  @@map("currency")
}

enum Availability {
  IN_STOCK     @map("in-stock")
  OUT_OF_STOCK @map("out-of-stock")
  UNKNOWN      @map("unknown")

  @@map("availability")
}

enum AlertStatus {
  ACTIVE      @map("active")
  PAUSED      @map("paused")
  TRIGGERED   @map("triggered")    // reserved for a future trigger engine; not written in W4a
  UNAVAILABLE @map("unavailable")  // reserved; derived at read time in W4a

  @@map("alert_status")
}

enum AlertIntent {
  ANY_DROP         @map("any-drop")
  BELOW_CURRENT    @map("below-current")
  FAVOURABLE_PRICE @map("favourable-price")
  CUSTOM_PRICE     @map("custom-price")

  @@map("alert_intent")
}

enum ScrapeRunKind {
  FULL_CATALOG           @map("full-catalog")
  WISHLIST_REFRESH       @map("wishlist-refresh")
  MANUAL                 @map("manual")
  DESCRIPTION_ENRICHMENT @map("description-enrichment")

  @@map("scrape_run_kind")
}

enum ScrapeRunStatus {
  RUNNING @map("running")
  SUCCESS @map("success")
  PARTIAL @map("partial")
  FAILED  @map("failed")

  @@map("scrape_run_status")
}

enum ScrapeRunTrigger {
  CRON   @map("cron")
  MANUAL @map("manual")
  SYSTEM @map("system")

  @@map("scrape_run_trigger")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model CanonicalBook {
  id        String   @id @default(uuid())
  title     String
  author    String
  /// null when no provider has supplied an ISBN for this book
  isbn      String?
  createdAt DateTime @default(now()) @map("created_at")

  listings      ProviderListing[]
  wishlistItems WishlistItem[]

  @@index([isbn])
  @@map("canonical_books")
}

model ProviderListing {
  id              String   @id @default(uuid())
  canonicalBookId String   @map("canonical_book_id")
  provider        Provider
  /// Title as it appears on the provider's site
  title           String
  /// Author as it appears on the provider's site
  author          String
  /// null when the provider page does not include an ISBN
  isbn            String?
  /// Price in the smallest currency unit (копійки). Always non-negative.
  priceAmount     Int      @map("price_amount")
  priceCurrency   Currency @map("price_currency")
  /// Direct URL to the book's page on the provider's site
  url             String
  lastSeenAt      DateTime @map("last_seen_at")
  availability    Availability @default(UNKNOWN) @map("availability")
  /// Cover image URL extracted from the provider's catalog card (W9a F1).
  /// null when the card exposed no usable image; enrichment never overwrites a known cover with null.
  coverUrl        String?  @map("cover_url")
  /// Sanitized plain-text description scraped from the provider's product page (W9a F2).
  /// null when the product page exposed no usable description; enrichment never overwrites a known description with null.
  description     String?  @map("description")

  canonicalBook CanonicalBook       @relation(fields: [canonicalBookId], references: [id])
  priceHistory  PriceHistoryPoint[]

  @@unique([provider, url])
  @@index([provider, canonicalBookId])
  @@map("provider_listings")
}

// append-only: INSERT only. No UPDATE or DELETE ever.
// A new row is recorded only when price OR availability changed (see price-history/service.ts).
model PriceHistoryPoint {
  id                String   @id @default(uuid())
  providerListingId String   @map("provider_listing_id")
  /// Price in the smallest currency unit (копійки). Always non-negative.
  priceAmount       Int      @map("price_amount")
  priceCurrency     Currency @map("price_currency")
  /// Availability of the listing at the moment this snapshot was recorded.
  availability      Availability @default(UNKNOWN) @map("availability")
  recordedAt        DateTime @map("recorded_at")

  providerListing ProviderListing @relation(fields: [providerListingId], references: [id])

  // Timeline / latest-price queries (ASC; Postgres scans backward for latest).
  @@index([providerListingId, recordedAt])
  // Lowest-price-ever queries and future verdict calculations.
  @@index([providerListingId, priceAmount])
  @@map("price_history")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  wishlistItems WishlistItem[]
  loginCodes    LoginCode[]
  sessions      Session[]

  @@map("users")
}

model LoginCode {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("login_codes")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model WishlistItem {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  canonicalBookId     String    @map("canonical_book_id")
  /// @deprecated — alerts own the threshold now (W4)
  /// null means no price alert is configured for this item
  targetPriceAmount   Int?      @map("target_price_amount")
  /// @deprecated — alerts own the threshold now (W4)
  targetPriceCurrency Currency? @map("target_price_currency")
  createdAt           DateTime  @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id])
  canonicalBook CanonicalBook @relation(fields: [canonicalBookId], references: [id])
  alert         Alert?

  @@unique([userId, canonicalBookId])
  @@map("wishlist_items")
}

model ScrapeRun {
  id                  String           @id @default(uuid())
  provider            Provider
  kind                ScrapeRunKind
  status              ScrapeRunStatus  @default(RUNNING)
  /// What initiated this run: scheduled cron, an explicit manual trigger, or an internal system process.
  triggeredBy         ScrapeRunTrigger @map("triggered_by")
  startedAt           DateTime         @map("started_at")
  finishedAt          DateTime?        @map("finished_at")
  durationMs          Int?             @map("duration_ms")
  itemsFound          Int              @default(0) @map("items_found")
  itemsUpdated        Int              @default(0) @map("items_updated")
  priceChanges        Int              @default(0) @map("price_changes")
  availabilityChanges Int              @default(0) @map("availability_changes")
  errorsCount         Int              @default(0) @map("errors_count")
  /// Truncated summary of the first few errors (null when none).
  errorSummary        String?          @map("error_summary")
  /// Free-form run context (scraper options used, target counts, etc.). Null when not applicable.
  metadata            Json?

  @@index([provider, kind, startedAt])
  @@map("scrape_runs")
}

model Alert {
  id                  String      @id @default(uuid())
  wishlistItemId      String      @unique @map("wishlist_item_id")
  status              AlertStatus @default(ACTIVE)
  intent              AlertIntent
  targetPriceAmount   Int         @map("target_price_amount")    // копійки
  targetPriceCurrency Currency    @map("target_price_currency")
  pausedAt            DateTime?   @map("paused_at")
  /// Dedup marker (W10.4): when this alert last fired a notification. Null until first notification.
  /// Reset to null when the price condition no longer holds, re-arming a future notification.
  lastNotifiedAt          DateTime? @map("last_notified_at")
  /// The lowest price (копійки) at the moment of the last notification. A subsequent
  /// notification fires only when the lowest price drops strictly below this value.
  lastNotifiedPriceAmount Int?      @map("last_notified_price_amount")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  wishlistItem WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)

  @@map("alerts")
}
