{
  "name": "@knyhovo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "prisma generate && tsc -p tsconfig.all.json",
    "test": "vitest run",
    "scrape": "tsx src/scripts/run-scrape.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@knyhovo/scrapers": "workspace:*",
    "@knyhovo/shared": "workspace:*",
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "catalog:",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
