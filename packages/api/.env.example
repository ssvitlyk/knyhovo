DATABASE_URL="postgresql://knyhovo:knyhovo@localhost:5432/knyhovo"
AUTH_SECRET=

# Ingestion runner (see docs/ops/scheduler.md)
# Run trigger classification: MANUAL | CRON | SYSTEM (default MANUAL)
SCRAPE_TRIGGERED_BY=MANUAL
# Operational interval convention; enforced by the Railway cron schedule, not by code.
SCRAPE_INTERVAL_HOURS=12
# Structured-log level for the pino-backed logger (default info)
LOG_LEVEL=info
