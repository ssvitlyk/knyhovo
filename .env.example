# Local development setup:
#   cp .env.example packages/api/.env
#
# Prisma CLI reads .env from packages/api/ (not the repo root).
# packages/api/.env is gitignored — never commit real secrets.

# PostgreSQL connection string for local development (matches docker-compose.yml)
DATABASE_URL="postgresql://knyhovo:knyhovo@localhost:5432/knyhovo"
